# ── Directus ─────────────────────────────────────────────────────────────────────
# Chaves de assinatura JWT do Directus (gera valores aleatórios para produção)
DIRECTUS_KEY=muda-isto-para-um-valor-secreto-aleatorio
DIRECTUS_SECRET=muda-isto-para-outro-valor-secreto-aleatorio

# ── Base de dados ─────────────────────────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=a-tua-password-da-base-de-dados

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────────
# Host do cluster (sem https://)
# Ex: c0014197-xxxx.eu-west-2-0.aws.cloud.qdrant.io
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_HTTPS=true
QDRANT_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_DIMENSIONS=768
