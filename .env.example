# ── Directus ─────────────────────────────────────────────────────────────────────
# Chaves de assinatura JWT do Directus — nunca partilhar nem versionar
DIRECTUS_KEY=
DIRECTUS_SECRET=

# ── Base de dados ─────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=
DB_USER=
DB_PASSWORD=

# ── Qdrant Cloud ────────────────────────────────────────────────────────────────
# Vai ao dashboard do Qdrant Cloud, clica no teu cluster e copia o host (sem https://)
# Exemplo: c0014197-e66a-4878-b993-XXXXXXXXXXXX.us-east4-0.gcp.cloud.qdrant.io
QDRANT_HOST=
QDRANT_PORT=
QDRANT_HTTPS=
QDRANT_API_KEY=

# ── Ollama ──────────────────────────────────────────────────────────────────────
OLLAMA_URL=
EMBEDDINGS_MODEL=
EMBEDDINGS_DIMENSIONS=

# ── Email ─────────────────────
EMAIL_TRANSPORT=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_SECURE=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=

# ── Segurança / CORS ──────────
PASSWORD_RESET_URL_ALLOW_LIST=
CORS_ORIGIN=

# ── Client (Injeção em Runtime) ──────────────────────────────────────────────────
VITE_DIRECTUS_URL=
VITE_FLOWISE_URL=
VITE_FLOWISE_CHATFLOW_ID=