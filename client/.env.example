# ── Directus ─────────────────────────────────────────────────────────────────────
# URL do servidor Directus (sem barra no final)
VITE_DIRECTUS_URL=http://localhost:8055

# ── Flowise ───────────────────────────────────────────────────────────────────────
# URL do servidor Flowise
VITE_FLOWISE_URL=http://localhost:3000

# ID do ChatFlow de geração de exercícios (obrigatório para o gerador funcionar)
# Encontra-o em Flowise → Chatflows → detalhes do flow
VITE_FLOWISE_CHATFLOW_ID=

# API Key do Flowise (opcional, mas recomendado em produção)
# Configura-a em Flowise → API Keys
VITE_FLOWISE_API_KEY=
